# --- Фронтенд (Vite) ---
# База API. По умолчанию "/api" (тот же домен, без CORS).
# Значение "local" — работа без бэкенда на localStorage (для разработки/демо).
VITE_API_BASE=/api

# Куда проксировать /api в dev-режиме (vite dev server). По умолчанию http://localhost:8000
# VITE_API_PROXY=http://localhost:8000

# --- Бэкенд (PHP) ---
# Реальные секреты держим в api/config.local.php (см. api/config.local.example.php),
# он в .gitignore. На Beget переменные можно задать и через окружение:
#   STRONGLOG_TOKEN  — секретный токен доступа (Bearer)
#   DB_HOST, DB_NAME, DB_USER, DB_PASS — доступ к MySQL
